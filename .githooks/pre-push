#!/usr/bin/env bash
# Pre-push hook: full static analysis + supply-chain + secret scanning.
# Runs once before push — heavier checks that don't belong in pre-commit.
#
# Install: git config core.hooksPath .githooks
set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

ERRORS=0

# ── Rust ─────────────────────────────────────────────────────────────────

echo "[pre-push] cargo fmt --all..."
if ! cargo fmt --all -- --check 2>&1; then
    echo "BLOCKED: Rust formatting errors. Run: cargo fmt --all"
    ERRORS=$((ERRORS + 1))
fi

echo "[pre-push] cargo clippy..."
# Lint only the processing library without OCR (no Tesseract required) and
# without the Tauri app (requires GTK/glib). Native system libraries are not
# present on headless build servers; CI runners build with full toolchain.
if ! cargo clippy -p ios-screen-time-image-pipeline --no-default-features -- -D warnings 2>&1; then
    echo "BLOCKED: clippy errors."
    ERRORS=$((ERRORS + 1))
fi

echo "[pre-push] cargo deny check..."
if ! cargo deny check 2>&1; then
    echo "BLOCKED: cargo-deny found license/advisory/ban violations."
    ERRORS=$((ERRORS + 1))
fi

# ── Python ───────────────────────────────────────────────────────────────

echo "[pre-push] bandit..."
if ! bandit -r src/ -ll -ii -q 2>&1; then
    echo "BLOCKED: bandit found MEDIUM+ severity/confidence issues."
    ERRORS=$((ERRORS + 1))
fi

echo "[pre-push] pip-audit..."
if ! pip-audit --no-deps -q 2>&1; then
    echo "BLOCKED: pip-audit found vulnerabilities in Python dependencies."
    ERRORS=$((ERRORS + 1))
fi

echo "[pre-push] deptry..."
if ! deptry . -q 2>&1; then
    echo "WARNING: deptry found unused/missing Python dependencies (non-blocking)."
fi

# ── SAST ─────────────────────────────────────────────────────────────────

echo "[pre-push] semgrep..."
if ! semgrep --config .semgrep.yml --error --quiet 2>&1; then
    echo "BLOCKED: semgrep found issues."
    ERRORS=$((ERRORS + 1))
fi

echo "[pre-push] ast-grep scan..."
if ! ast-grep scan --config sgconfig.yml --error 2>&1; then
    echo "BLOCKED: ast-grep found error-severity issues."
    ERRORS=$((ERRORS + 1))
fi

# ── YAML ─────────────────────────────────────────────────────────────────

echo "[pre-push] yamllint..."
if ! yamllint -c .yamllint.yml docker/ .github/ 2>&1; then
    echo "BLOCKED: yamllint found YAML formatting issues."
    ERRORS=$((ERRORS + 1))
fi

# ── Architecture invariants ───────────────────────────────────────────────

echo "[pre-push] architecture invariants..."
if ! scripts/check-architecture-invariants.sh 2>&1; then
    echo "BLOCKED: architecture invariant check failed."
    ERRORS=$((ERRORS + 1))
fi

# ── Frontend ─────────────────────────────────────────────────────────────

if command -v bun &>/dev/null; then
    echo "[pre-push] knip (dead TypeScript exports)..."
    if ! cd frontend && bun x knip --no-exit-code 2>&1; then
        echo "WARNING: knip found dead code (non-blocking)."
    fi
    cd "$REPO_ROOT"
fi

# ── Secrets ──────────────────────────────────────────────────────────────

echo "[pre-push] gitleaks..."
if ! gitleaks protect --staged -v 2>&1; then
    echo "BLOCKED: gitleaks found secrets in staged/committed files."
    ERRORS=$((ERRORS + 1))
fi

# ─────────────────────────────────────────────────────────────────────────

if [ "$ERRORS" -gt 0 ]; then
    echo ""
    echo "Push blocked by $ERRORS check(s). Fix before pushing."
    exit 1
fi

echo "[pre-push] All checks passed."
