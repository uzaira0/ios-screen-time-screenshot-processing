# iOS Screen Time Screenshot Processing Configuration
# Copy this to .env and fill in real values

# ========================================
# REQUIRED SETTINGS
# ========================================

# Secret key for session security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_HEX_STRING

# API key for programmatic uploads (Dagster, external pipelines)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
UPLOAD_API_KEY=CHANGE_THIS_TO_A_RANDOM_API_KEY

# ========================================
# DATABASE CONFIGURATION
# ========================================

# For Docker Compose (full stack):
# DATABASE_URL=postgresql+asyncpg://screenshot:screenshot@postgres:5432/screenshot_annotations

# For local development with docker-compose.dev.yml:
DATABASE_URL=postgresql+asyncpg://screenshot:screenshot@localhost:5433/screenshot_annotations

# PostgreSQL credentials (used by Docker)
POSTGRES_USER=screenshot
POSTGRES_PASSWORD=screenshot
POSTGRES_DB=screenshot_annotations

# ========================================
# APPLICATION SETTINGS
# ========================================

DEBUG=false
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated, no wildcards allowed for security)
# Must be valid http:// or https:// URLs
CORS_ORIGINS=http://localhost:3002,http://localhost:5173

# Admin usernames whitelist (comma-separated)
# Only these usernames will be granted admin role on first login
ADMIN_USERNAMES=admin

# ========================================
# LOGGING CONFIGURATION
# ========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: 'json' for structured JSON (production), 'text' for human-readable (development)
LOG_FORMAT=text

# ========================================
# RATE LIMITING
# ========================================

# Default rate limit for all API endpoints
RATE_LIMIT_DEFAULT=100/minute

# Rate limit for screenshot upload endpoint
RATE_LIMIT_UPLOAD=10/minute

# Rate limit for reprocessing endpoints
RATE_LIMIT_REPROCESS=30/minute

# ========================================
# DOCKER COMPOSE SETTINGS
# ========================================

# Ports (change if conflicts with other services)
BACKEND_PORT=8002
FRONTEND_PORT=3002

# Screenshot source directory - mount into container
# On Windows: SCREENSHOT_SOURCE_PATH=/path/to/screenshots
# On Linux: SCREENSHOT_SOURCE_PATH=/mnt/network/screenshots
SCREENSHOT_SOURCE_PATH=./screenshots

# ========================================
# PROCESSING OPTIONS
# ========================================

# Store hourly values as floats (2 decimal places) instead of integers.
# This improves accuracy since the sum of rounded integers can drift from the true total.
# Set to false to use legacy integer rounding behavior.
USE_FRACTIONAL_HOURLY_VALUES=true

# ========================================
# ANNOTATION CONSENSUS CONFIGURATION
# ========================================

# Disagreement threshold in minutes (0 = any difference flags for review)
CONSENSUS_DISAGREEMENT_THRESHOLD_MINUTES=0

# Severity classification thresholds (minutes)
CONSENSUS_MINOR_THRESHOLD=2
CONSENSUS_MODERATE_THRESHOLD=5

# ========================================
# OCR CONFIGURATION
# ========================================

# OCR engine type: tesseract, paddleocr, paddleocr_remote, hunyuan, or hybrid
OCR_ENGINE_TYPE=hybrid

# HunyuanOCR vLLM endpoint (local network, not internet)
HUNYUAN_OCR_URL=http://YOUR_OCR_HOST:8080
HUNYUAN_OCR_TIMEOUT=120

# PaddleOCR HTTP API endpoint (local network, not internet)
PADDLEOCR_URL=http://YOUR_OCR_HOST:8081
PADDLEOCR_TIMEOUT=60

# Hybrid engine: toggle individual backends
HYBRID_ENABLE_HUNYUAN=true
HYBRID_ENABLE_PADDLEOCR=true
HYBRID_ENABLE_TESSERACT=true

# ========================================
# PREPROCESSING PIPELINE
# ========================================

# Global toggle for preprocessing (device detection, cropping, PHI redaction)
PREPROCESSING_ENABLED=false

# PHI detection settings
PHI_DETECTION_ENABLED=true
PHI_PIPELINE_PRESET=hipaa_compliant
PHI_REDACTION_METHOD=redbox

# Save debug images during processing
SAVE_DEBUG_IMAGES=false

# ========================================
# CELERY/REDIS (Background Tasks)
# ========================================

# For Docker Compose:
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# For local development:
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
