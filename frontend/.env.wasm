# WASM Mode Configuration
VITE_DEFAULT_MODE=wasm
VITE_FORCE_WASM=true

# No backend API needed
# VITE_API_URL is intentionally not set

# App Configuration
VITE_APP_NAME=Screenshot Processor
VITE_APP_VERSION=1.0.0

# PWA Configuration
VITE_PWA_ENABLED=true
VITE_PWA_CACHE_NAME=screenshot-processor-v1

# Performance
VITE_ENABLE_LAZY_LOADING=true
VITE_ENABLE_CODE_SPLITTING=true

# Debug (set to false for production)
VITE_DEBUG=false
