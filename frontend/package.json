{
  "name": "screenshot-annotation-frontend",
  "version": "0.5.1",
  "type": "module",
  "scripts": {
    "dev": "bun run server/dev.ts",
    "build": "bun run typecheck && bun run server/build.ts",
    "preview": "bun run dist/index.html",
    "typecheck": "bunx tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "check": "bun run typecheck && bun run lint",
    "generate:api-types": "cd .. && python -c \"import sys; sys.path.insert(0, 'src'); from screenshot_processor.web.api.main import app; import json; print(json.dumps(app.openapi(), indent=2))\" > frontend/openapi.json && cd frontend && bunx openapi-typescript ./openapi.json -o src/types/api-schema.ts",
    "test": "bun test src/",
    "test:watch": "bun test src/ --watch",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:headed": "bunx playwright test --headed",
    "test:e2e:debug": "bunx playwright test --debug",
    "test:e2e:report": "bunx playwright show-report",
    "test:a11y": "bunx playwright test tests/accessibility/",
    "check-drift": "./scripts/check-contract-drift.sh",
    "size-check": "bun run build && bunx size-limit",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tailwindcss/cli": "^4.2.1",
    "@tanstack/react-virtual": "^3.13.21",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-log": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-os": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@tauri-apps/plugin-window-state": "^2",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "lucide-react": "^0.577.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.5",
    "react-hot-toast": "^2.4.1",
    "react-router": "^7.13.1",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@size-limit/preset-app": "^11",
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@types/bun": "latest",
    "@types/node": "^22.10.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "fast-check": "^4",
    "globals": "^16.5.0",
    "happy-dom": "^20.0.0",
    "openapi-typescript": "^7.10.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^11",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.50.1",
    "vite": "^6"
  }
}
