import { describe, it, expect, beforeEach, afterEach } from 'vitest';
import { IndexedDBStorageService } from '../IndexedDBStorageService';
import { db } from '../database';
import type { Screenshot, Annotation } from '../../../../models';

describe('IndexedDBStorageService', () => {
  let service: IndexedDBStorageService;

  beforeEach(async () => {
    service = new IndexedDBStorageService();
    await db.open();
    await service.clearAll();
  });

  afterEach(async () => {
    await service.clearAll();
  });

  describe('Screenshot Operations', () => {
    it('should save a screenshot', async () => {
      const screenshot: Screenshot = {
        id: 0,
        file_path: 'test.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      const id = await service.saveScreenshot(screenshot);

      expect(id).toBeGreaterThan(0);
    });

    it('should retrieve a saved screenshot', async () => {
      const screenshot: Screenshot = {
        id: 0,
        file_path: 'test.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      const id = await service.saveScreenshot(screenshot);
      const retrieved = await service.getScreenshot(id);

      expect(retrieved).not.toBeNull();
      expect(retrieved?.file_path).toBe('test.png');
      expect(retrieved?.image_type).toBe('battery');
    });

    it('should update a screenshot', async () => {
      const screenshot: Screenshot = {
        id: 0,
        file_path: 'test.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      const id = await service.saveScreenshot(screenshot);

      await service.updateScreenshot(id, {
        status: 'completed',
        processing_status: 'completed'
      });

      const updated = await service.getScreenshot(id);

      expect(updated?.status).toBe('completed');
      expect(updated?.processing_status).toBe('completed');
    });

    it('should get all screenshots', async () => {
      const screenshot1: Screenshot = {
        id: 0,
        file_path: 'test1.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      const screenshot2: Screenshot = {
        ...screenshot1,
        file_path: 'test2.png',
        status: 'completed'
      };

      await service.saveScreenshot(screenshot1);
      await service.saveScreenshot(screenshot2);

      const allScreenshots = await service.getAllScreenshots();
      expect(allScreenshots.length).toBe(2);

      const pendingScreenshots = await service.getAllScreenshots({ status: 'pending' });
      expect(pendingScreenshots.length).toBe(1);

      const completedScreenshots = await service.getAllScreenshots({ status: 'completed' });
      expect(completedScreenshots.length).toBe(1);
    });

    it('should delete a screenshot', async () => {
      const screenshot: Screenshot = {
        id: 0,
        file_path: 'test.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      const id = await service.saveScreenshot(screenshot);

      await service.deleteScreenshot(id);

      const deleted = await service.getScreenshot(id);
      expect(deleted).toBeNull();
    });
  });

  describe('Annotation Operations', () => {
    it('should save an annotation', async () => {
      const screenshot: Screenshot = {
        id: 0,
        file_path: 'test.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      const screenshotId = await service.saveScreenshot(screenshot);

      const annotation: Annotation = {
        id: 0,
        screenshot_id: screenshotId,
        annotator_id: 1,
        hourly_values: { '0': 10, '1': 20 },
        status: 'submitted',
        created_at: new Date().toISOString(),
        updated_at: new Date().toISOString()
      };

      const id = await service.saveAnnotation(annotation);

      expect(id).toBeGreaterThan(0);
    });

    it('should retrieve an annotation', async () => {
      const screenshot: Screenshot = {
        id: 0,
        file_path: 'test.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      const screenshotId = await service.saveScreenshot(screenshot);

      const annotation: Annotation = {
        id: 0,
        screenshot_id: screenshotId,
        annotator_id: 1,
        hourly_values: { '0': 10, '1': 20 },
        status: 'submitted',
        created_at: new Date().toISOString(),
        updated_at: new Date().toISOString()
      };

      const id = await service.saveAnnotation(annotation);
      const retrieved = await service.getAnnotation(id);

      expect(retrieved).not.toBeNull();
      expect(retrieved?.screenshot_id).toBe(screenshotId);
    });

    it('should get annotations by screenshot', async () => {
      const screenshot: Screenshot = {
        id: 0,
        file_path: 'test.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      const screenshotId = await service.saveScreenshot(screenshot);

      const annotation1: Annotation = {
        id: 0,
        screenshot_id: screenshotId,
        annotator_id: 1,
        hourly_values: { '0': 10, '1': 20 },
        status: 'submitted',
        created_at: new Date().toISOString(),
        updated_at: new Date().toISOString()
      };

      const annotation2: Annotation = {
        id: 0,
        screenshot_id: screenshotId,
        annotator_id: 2,
        hourly_values: { '0': 11, '1': 21 },
        status: 'submitted',
        created_at: new Date().toISOString(),
        updated_at: new Date().toISOString()
      };

      await service.saveAnnotation(annotation1);
      await service.saveAnnotation(annotation2);

      const annotations = await service.getAnnotationsByScreenshot(screenshotId);

      expect(annotations.length).toBe(2);
    });

    it('should update screenshot annotation count when saving annotation', async () => {
      const screenshot: Screenshot = {
        id: 0,
        file_path: 'test.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      const screenshotId = await service.saveScreenshot(screenshot);

      const annotation: Annotation = {
        id: 0,
        screenshot_id: screenshotId,
        annotator_id: 1,
        hourly_values: { '0': 10, '1': 20 },
        status: 'submitted',
        created_at: new Date().toISOString(),
        updated_at: new Date().toISOString()
      };

      await service.saveAnnotation(annotation);

      const updated = await service.getScreenshot(screenshotId);

      expect(updated?.current_annotation_count).toBe(1);
    });

    it('should delete an annotation', async () => {
      const screenshot: Screenshot = {
        id: 0,
        file_path: 'test.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      const screenshotId = await service.saveScreenshot(screenshot);

      const annotation: Annotation = {
        id: 0,
        screenshot_id: screenshotId,
        annotator_id: 1,
        hourly_values: { '0': 10, '1': 20 },
        status: 'submitted',
        created_at: new Date().toISOString(),
        updated_at: new Date().toISOString()
      };

      const id = await service.saveAnnotation(annotation);

      await service.deleteAnnotation(id);

      const deleted = await service.getAnnotation(id);
      expect(deleted).toBeNull();
    });
  });

  describe('Blob Operations', () => {
    it('should save and retrieve an image blob', async () => {
      const screenshotId = 1;
      const blob = new Blob(['test image data'], { type: 'image/png' });

      await service.saveImageBlob(screenshotId, blob);

      const retrieved = await service.getImageBlob(screenshotId);

      expect(retrieved).not.toBeNull();
      expect(retrieved?.size).toBe(blob.size);
      expect(retrieved?.type).toBe(blob.type);
    });
  });

  describe('Bulk Operations', () => {
    it('should bulk save screenshots', async () => {
      const screenshots: Screenshot[] = [
        {
          id: 0,
          file_path: 'test1.png',
          image_type: 'battery',
          uploaded_at: new Date().toISOString(),
          uploaded_by_id: null,
          current_annotation_count: 0,
          target_annotations: 1,
          has_consensus: null,
          status: 'pending',
          processed_at: null,
          processing_status: 'pending',
          extracted_title: null,
          extracted_total: null,
          extracted_hourly_data: null,
          title_y_position: null,
          grid_upper_left_x: null,
          grid_upper_left_y: null,
          grid_lower_right_x: null,
          grid_lower_right_y: null,
          processing_issues: null,
          has_blocking_issues: false
        },
        {
          id: 0,
          file_path: 'test2.png',
          image_type: 'screen_time',
          uploaded_at: new Date().toISOString(),
          uploaded_by_id: null,
          current_annotation_count: 0,
          target_annotations: 1,
          has_consensus: null,
          status: 'pending',
          processed_at: null,
          processing_status: 'pending',
          extracted_title: null,
          extracted_total: null,
          extracted_hourly_data: null,
          title_y_position: null,
          grid_upper_left_x: null,
          grid_upper_left_y: null,
          grid_lower_right_x: null,
          grid_lower_right_y: null,
          processing_issues: null,
          has_blocking_issues: false
        }
      ];

      const ids = await service.bulkSaveScreenshots(screenshots);

      expect(ids.length).toBe(2);
    });
  });

  describe('Stats Operations', () => {
    it('should return database stats', async () => {
      const screenshot: Screenshot = {
        id: 0,
        file_path: 'test.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      await service.saveScreenshot(screenshot);

      const stats = await service.getStats();

      expect(stats.screenshotCount).toBe(1);
      expect(stats.annotationCount).toBe(0);
    });
  });

  describe('Clear Operations', () => {
    it('should clear all data', async () => {
      const screenshot: Screenshot = {
        id: 0,
        file_path: 'test.png',
        image_type: 'battery',
        uploaded_at: new Date().toISOString(),
        uploaded_by_id: null,
        current_annotation_count: 0,
        target_annotations: 1,
        has_consensus: null,
        status: 'pending',
        processed_at: null,
        processing_status: 'pending',
        extracted_title: null,
        extracted_total: null,
        extracted_hourly_data: null,
        title_y_position: null,
        grid_upper_left_x: null,
        grid_upper_left_y: null,
        grid_lower_right_x: null,
        grid_lower_right_y: null,
        processing_issues: null,
        has_blocking_issues: false
      };

      await service.saveScreenshot(screenshot);

      await service.clearAll();

      const screenshots = await service.getAllScreenshots();
      expect(screenshots.length).toBe(0);
    });
  });
});
