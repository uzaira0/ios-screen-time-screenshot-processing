# Screenshot Processor - Environment Configuration
# Copy this file to .env and configure for your deployment mode

# =============================================================================
# MODE SELECTION
# =============================================================================
#
# The application supports two modes:
#
# 1. WASM Mode (Default - Standalone)
#    - 100% offline processing in the browser
#    - No backend required
#    - All data stored locally in IndexedDB
#    - Complete privacy - data never leaves the device
#    - To use: Simply don't set VITE_API_BASE_URL (or leave it empty)
#
# 2. Server Mode (Collaborative)
#    - Backend API for processing
#    - Multi-user collaboration features
#    - Real-time updates via WebSocket
#    - Centralized data storage
#    - To use: Set VITE_API_BASE_URL to your backend URL
#
# =============================================================================

# Backend API Base URL (leave empty or comment out for WASM mode)
# For WASM mode: Leave this commented out or empty
# VITE_API_BASE_URL=

# For Server mode: Uncomment and set to your backend URL
# VITE_API_BASE_URL=http://localhost:8000/api
# VITE_API_BASE_URL=https://api.example.com/api

# =============================================================================
# PWA CONFIGURATION (Optional)
# =============================================================================

# App Name (shown in PWA install prompt)
# VITE_APP_NAME=Screenshot Processor

# App Short Name (shown on home screen)
# VITE_APP_SHORT_NAME=ScreenProc

# Theme Color
# VITE_THEME_COLOR=#3B82F6

# =============================================================================
# ADVANCED CONFIGURATION (Optional)
# =============================================================================

# Enable service worker for offline support (default: true in production)
# VITE_ENABLE_SW=true

# Enable debug mode (shows extra logging)
# VITE_DEBUG=false

# =============================================================================
# DEPLOYMENT EXAMPLES
# =============================================================================

# Example 1: Local WASM Mode (no backend)
# Just run: npm run dev
# (No .env file needed, or use this file with VITE_API_BASE_URL commented out)

# Example 2: Local Development with Backend
# VITE_API_BASE_URL=http://localhost:8000/api

# Example 3: Production Server Mode
# VITE_API_BASE_URL=https://api.yourcompany.com/api
# VITE_ENABLE_SW=true

# Example 4: Hybrid Mode (both WASM and Server available)
# VITE_API_BASE_URL=https://api.yourcompany.com/api
# Users can switch between modes in Settings

# =============================================================================
# NOTES
# =============================================================================
#
# - Environment variables must start with VITE_ to be accessible in the app
# - Changes to .env require restarting the dev server (npm run dev)
# - For production builds, set environment variables before building
# - WASM mode is the default and recommended for most users
# - Server mode requires a running backend (see backend documentation)
#
