# =============================================================================
# iOS Screen Time Screenshot Processing - Production Environment
# =============================================================================
# Copy to .env and fill in values

# ---------------------------------------------------------------------------
# Deploy Script Config (required)
# ---------------------------------------------------------------------------
APP_NAME=ios-screen-time-screenshot-processing
IMAGE_PREFIX=uzaira0/monorepo/ios-screen-time-screenshot-processing
HEALTH_URL=http://localhost:8000/health
HEALTH_TIMEOUT=120

# ---------------------------------------------------------------------------
# Database (password only - user/db are hardcoded)
# ---------------------------------------------------------------------------
# User: ios_screen_time_screenshot
# Database: ios_screen_time_screenshot_processing
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING
UPLOAD_API_KEY=CHANGE_ME_API_KEY
SITE_PASSWORD=CHANGE_ME_SITE_PASSWORD
CORS_ORIGINS=https://your-domain.com

# ---------------------------------------------------------------------------
# Screenshot Source (read-only mount)
# ---------------------------------------------------------------------------
SCREENSHOT_SOURCE_PATH=/path/to/screenshots

# ---------------------------------------------------------------------------
# Optional (defaults shown, uncomment to override)
# ---------------------------------------------------------------------------
# RATE_LIMIT_DEFAULT=100/minute
# USE_FRACTIONAL_HOURLY_VALUES=false
# DEBUG=false
