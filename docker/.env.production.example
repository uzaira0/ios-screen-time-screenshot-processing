# =============================================================================
# Production Environment Configuration - ios-screen-time-screenshot-processing
# =============================================================================
# Copy this file to .env and configure with real values.
# NEVER commit .env to version control!
#
# Generate secrets:
#   SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
#   UPLOAD_API_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   POSTGRES_PASSWORD: python -c "import secrets; print(secrets.token_urlsafe(24))"
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=screenshot
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD
POSTGRES_DB=screenshot_annotations

# -----------------------------------------------------------------------------
# Application Security
# -----------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_GENERATE_64_HEX_CHARACTERS
UPLOAD_API_KEY=CHANGE_ME_GENERATE_SECURE_API_KEY
ADMIN_USERNAMES=admin

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# With Traefik, set to the Traefik URL (same origin)
CORS_ORIGINS=http://localhost

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
DEBUG=false
RATE_LIMIT_DEFAULT=100/minute

# -----------------------------------------------------------------------------
# App-Specific Settings
# -----------------------------------------------------------------------------
USE_FRACTIONAL_HOURLY_VALUES=true
# SCREENSHOT_SOURCE_PATH=/path/to/screenshots

# -----------------------------------------------------------------------------
# Port Configuration (for direct DB access if needed)
# -----------------------------------------------------------------------------
POSTGRES_PORT=5433
REDIS_PORT=6380
